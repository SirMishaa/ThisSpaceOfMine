passlist "Skybox"
{
    attachment "DepthBuffer"
    {
        format "PreferredDepthStencil"
    }

    attachment "ForwardOutput"
    {
        format "RGBA8"
    }

    pass "Skybox rendering"
    {
        impl "Forward"
        output "Output" "ForwardOutput"
        cleardepth "Viewer"
        depthstenciloutput "DepthBuffer"
    }

    output "ForwardOutput"
}
